#!/usr/bin/env node
const path = require('path');
const spawn = require('child_process').spawn;
const os = require('os');

const platform = os.platform();
let binaryName = 'lumina-bin';

if (platform === 'win32') {
  binaryName += '.exe';
}

const binaryPath = path.join(__dirname, '..', 'bin', binaryName);

const child = spawn(binaryPath, process.argv.slice(2), {
  stdio: 'inherit'
});

child.on('error', (err) => {
  if (err.code === 'ENOENT') {
    console.error('Lumina binary not found. Please reinstall the package.');
  } else {
    console.error(`Error running Lumina: ${err.message}`);
  }
  process.exit(1);
});

child.on('exit', (code) => {
  process.exit(code);
});
