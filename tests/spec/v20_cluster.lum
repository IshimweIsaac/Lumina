-- Lumina v2.0 Sovereignty & Cluster Spec Test
cluster {
  node_id: "node-1"
  peers: ["node-2", "node-3"]
  quorum: 2
  election_timeout: 1.5 s
}

entity Workload {
  cpu: Number
  zone: String
  isHot := cpu > 80
}

-- Local aggregate: computes over this node's instances
aggregate NodeStats over Workload {
  total_cpu := sum(cpu)
  avg_cpu   := avg(cpu)
  max_cpu   := max(cpu)
}

-- Create workloads on this node
let AppMain = Workload { cpu: 85, zone: "us-east-1" }
let AppDB   = Workload { cpu: 20, zone: "us-east-1" }

-- Rule: fires when local node total CPU exceeds threshold
rule "NodeOverloaded"
when NodeStats.total_cpu > 100 {
  show "Node CPU total is {NodeStats.total_cpu}% (avg: {NodeStats.avg_cpu}%, max: {NodeStats.max_cpu}%)"
}

-- Rule: fires when any individual workload is hot
rule "HotWorkload"
when Workload.isHot becomes true {
  show "Workload is running hot at {Workload.cpu}% CPU"
}
