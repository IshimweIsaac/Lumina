entity Thermostat {
    temp: Number
    target: Number
    status := if temp < target then "Heating" else "Idle"
}
--Instance
let t = Thermostat { temp: 20, target: 22 }

--Rules
rule "On"  { when t.status becomes "Heating" then show "Temperature: {t.status}" }
rule "Off" { when t.status becomes "Idle"    then show "Temperature: {t.status}" }

--Test
update t.temp to 25 -- Should show Idle
update t.temp to 15 -- Should show Heating

