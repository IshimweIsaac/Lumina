entity Clock {
    ticks: Number
}

let c = Clock { ticks: 0 }

-- This is the "Perpetual" rule
rule "Heartbeat" 
    every 1 s
    then update c.ticks to c.ticks + 1
    then show "Tick #{c.ticks}"


-- This is the "Safety" rule
rule "Limit" {
    when c.ticks >= 10
    then show "Reached limit! Stopping system..."
}
