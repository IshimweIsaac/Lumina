entity Thermostat {
    temp: Number
    target: Number
    isCold := temp < target
}

let myThermostat = Thermostat {
    temp: 20,
    target: 22
}

rule "Heating on" {
    when myThermostat.isCold becomes true
    then show "Heating is on!"
}

update myThermostat.temp to 25
update myThermostat.temp to 15
